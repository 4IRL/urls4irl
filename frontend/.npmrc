# openapi-typescript@7.13.0 requires typescript@^5.x but the project uses
# typescript@6.0.2. All affected packages are devDependencies, so the risk
# of this blanket flag is low.
legacy-peer-deps=true

# Supply-chain hygiene: refuse to install any package version published less
# than 90 days ago (~3 months). Reduces exposure to malicious packages that
# rely on rapid automated consumption before detection or takedown. Requires
# npm >= 11.10.0. Override per-install with `npm i --min-release-age 0 <pkg>`
# for urgent security fixes.
min-release-age=90
