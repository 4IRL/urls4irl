{
  "name": "u4i-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config ./frontend/vitest.config.ts",
    "test:watch": "vitest --config ./frontend/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config ./frontend/vitest.config.ts",
    "typecheck": "tsc --noEmit --project frontend/tsconfig.json && tsc --noEmit --project frontend/tsconfig.test.json"
  },
  "devDependencies": {
    "@types/bootstrap": "5.2.10",
    "@types/jquery": "3.5.34",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitejs/plugin-basic-ssl": "2.1.4",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "10.4.27",
    "bootstrap": "5.2.3",
    "eslint": "9.39.4",
    "font-awesome": "4.7.0",
    "happy-dom": "20.8.9",
    "jquery": "3.7.1",
    "openapi-typescript": "7.13.0",
    "postcss-preset-env": "11.2.0",
    "typescript": "6.0.2",
    "vite": "7.3.2",
    "vitest": "4.1.0"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "postcss": "8.5.15"
  }
}
