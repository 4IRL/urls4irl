# ---------------------------------------------------------------------------
# OAuth provider credentials (Google + GitHub)
# ---------------------------------------------------------------------------
# ALL FIVE keys below are OPTIONAL. Leave them empty and the app boots normally
# with OAuth disabled — no ValueError is raised for a missing key. Populate them
# only when you want to enable "Sign in with Google" / "Sign in with GitHub".
#
# Register a SEPARATE OAuth client per environment (local / dev / prod) so a
# leaked credential in one environment can never authorize a callback in another.
#
# OAUTH_REDIRECT_BASE_URL is the single source of truth for the callback origin.
# The OAuth code computes callback URLs as:
#     f"{OAUTH_REDIRECT_BASE_URL}/oauth/{provider}/callback"
# It MUST NOT be derived from url_for(..., _external=True), which depends on
# fragile X-Forwarded-Host / X-Forwarded-Proto proxy headers.
#
# Local callback URLs to register on each provider's console:
#   Google: http://127.0.0.1:8659/oauth/google/callback
#   GitHub: http://127.0.0.1:8659/oauth/github/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8659
